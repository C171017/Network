# Local dev for API (`npm run dev:server` from repo root).
# Copy to `apps/server/.env` (never commit real values).
#
# The server loads, in order: `<repo>/.env` then `apps/server/.env` (later wins).
# Paths are resolved from this package so changing `cwd` still finds `apps/server/.env`.

SUPABASE_URL=
SUPABASE_ANON_KEY=

# Must match the browser origin you use to open the Vite app (default CRA/Vite port).
CORS_ORIGIN=http://localhost:5173

# API bind port
PORT=8787
