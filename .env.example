# Copy to `.env` locally (never commit `.env`).
# Required to run the GitHub network crawler (`npm run crawl`).

GITHUB_TOKEN=
# or: GH_TOKEN=

# GitHub username to start the crawl from (your account for testing).
SEED_LOGIN=

# Optional — default ./data/network.db
# DB_PATH=./data/network.db

# Optional — only set when you want a FRESH empty DB for this run only.
# Leave unset so multiple runs ACCUMULATE (duplicates ignored).
# RESET_DB=1

# Optional crawl tuning (defaults shown in packages/crawler/README.md)
# BRANCH_SAMPLE=6
# MAX_DEPTH=5
# MAX_PAGES_PER_SIDE=3
# MAX_EXPANSIONS=200

# --- Web + API (Supabase GitHub OAuth demo) ---
# Prefer dedicated files:
# - apps/web/.env        (VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY)
# - apps/server/.env     (SUPABASE_URL, SUPABASE_ANON_KEY, CORS_ORIGIN, PORT)
#
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# CORS_ORIGIN=http://localhost:5173
# PORT=8787
